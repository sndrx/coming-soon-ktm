      "namedRegex": "^/demo\\-5(?:/)?$"
    },
    {
      "page": "/demo-6",
      "regex": "^/demo\\-6(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/demo\\-6(?:/)?$"
    },
    {
      "page": "/demo-7",
